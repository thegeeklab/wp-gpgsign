FROM --platform=$BUILDPLATFORM docker.io/library/golang:1.26.1@sha256:595c7847cff97c9a9e76f015083c481d26078f961c9c8dca3923132f51fe12f1 AS build

ARG TARGETOS
ARG TARGETARCH

ADD . /src
WORKDIR /src

RUN make build

FROM docker.io/library/alpine:3.23@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659

LABEL maintainer="Robert Kaussow <mail@thegeeklab.de>"
LABEL org.opencontainers.image.authors="Robert Kaussow <mail@thegeeklab.de>"
LABEL org.opencontainers.image.title="wp-gpgsign"
LABEL org.opencontainers.image.url="https://github.com/thegeeklab/wp-gpgsign"
LABEL org.opencontainers.image.source="https://github.com/thegeeklab/wp-gpgsign"
LABEL org.opencontainers.image.documentation="https://github.com/thegeeklab/wp-gpgsign"

ARG TARGETOS
ARG TARGETARCH

RUN apk add --no-cache gnupg && \
    apk upgrade --no-cache zlib && \
    rm -rf /var/cache/apk/* && \
    rm -rf /tmp/* && \
    rm -rf /root/.cache/

COPY --from=build /src/dist/wp-gpgsign /bin/wp-gpgsign
ENTRYPOINT ["/bin/wp-gpgsign"]
